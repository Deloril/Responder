# `Project: Responder` ‚Äî local environment configuration
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# All TF_VAR_* entries are picked up automatically by terraform. The Makefile
# `-include`s this file and exports its values, so `make build-<region>` will
# load them transparently. If you invoke terraform directly, run
# `set -a; source .env; set +a` first (or use `make`).

##############################################
## Terraform state backend (S3)
## Used by `make init` to populate the partial backend config in main.tf.
##############################################
TERRAFORM_STATE_BUCKET=                    # e.g. my-org-project-responder-terraform

##############################################
## TF_VAR_* values consumed by terraform
##############################################

# AWS account ID that owns the deployment, the custom Windows client AMI, and
# the multi-region KMS key used for EBS encryption.
TF_VAR_aws_account_id=                     # 12-digit AWS account number

# KMS key ID (the bit after `key/` in the ARN) of the multi-region key used to
# encrypt root volumes for every instance in the lab.
TF_VAR_kms_key_id=                         # e.g. mrk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Local AWS CLI credential profile name (must have admin access to the account
# above). `terraform` honours $AWS_PROFILE; this is also exported below.
AWS_PROFILE=

# The public IP of the machine running terraform is detected and allowlisted
# automatically at apply time, so the lab "just works" from wherever you run
# `make build-*`. Set extra_trusted_networks only if you need additional CIDRs
# (e.g. a teammate's IP, a corp VPN range). HCL/JSON list, no surrounding
# quotes -- Make exports the value verbatim and terraform will reject single
# quotes. Example:
#   TF_VAR_extra_trusted_networks=["203.0.113.0/24","198.51.100.10/32"]
TF_VAR_extra_trusted_networks=
